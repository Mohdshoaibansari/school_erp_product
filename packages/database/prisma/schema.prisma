generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Tenant ────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String   @unique
  subdomain String   @unique
  status    String   @default("ACTIVE") // ACTIVE | SUSPENDED | ARCHIVED
  studentLimit Int   @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       UserTenant[]
  modules     TenantModule[]
  levelDefs   LevelDefinition[]
  subjects    Subject[]
  acadYears   AcademicYear[]

  @@map("tenants")
}

// ─── Identity & Roles ──────────────────────────────────

model User {
  id        String   @id @default(uuid())
  supabaseId String  @unique
  email     String
  name      String
  phone     String?
  status    String   @default("ACTIVE") // INVITED | ACTIVE | SUSPENDED | ARCHIVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenants    UserTenant[]
  classTeachers  ClassTeacher[]
  subjectTeachers SubjectTeacher[]

  @@map("users")
}

model UserTenant {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     String // SUPER_ADMIN | SCHOOL_ADMIN | PRINCIPAL | TEACHER | ACCOUNTANT

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
  @@map("user_tenants")
}

// ─── Subscription ──────────────────────────────────────

model TenantModule {
  id        String @id @default(uuid())
  tenantId  String
  moduleName String // students | attendance | fees | timetable | exams
  enabled   Boolean @default(true)
  isPaid    Boolean @default(false)

  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleName])
  @@map("tenant_modules")
}

// ─── Academic Structure ────────────────────────────────

model AcademicYear {
  id        String   @id @default(uuid())
  tenantId  String
  name      String   // "2026-27"
  startDate DateTime
  endDate   DateTime
  status    String   @default("DRAFT") // DRAFT | ACTIVE | COMPLETED

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  enrollments StudentEnrollment[]

  @@unique([tenantId, name])
  @@map("academic_years")
}

model LevelDefinition {
  id           String  @id @default(uuid())
  tenantId     String
  name         String  // "Class", "Section", "Stream"
  displayOrder Int
  isRequired   Boolean @default(true)

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  instances LevelInstance[]

  @@unique([tenantId, name])
  @@map("level_definitions")
}

model LevelInstance {
  id         String  @id @default(uuid())
  tenantId   String
  levelDefId String
  name       String  // "5", "A", "Science"
  parentId   String?
  isActive   Boolean @default(true)

  definition  LevelDefinition @relation(fields: [levelDefId], references: [id])
  parent      LevelInstance?  @relation("LevelTree", fields: [parentId], references: [id])
  children    LevelInstance[] @relation("LevelTree")
  classTeachers    ClassTeacher[]
  subjectTeachers  SubjectTeacher[]
  studentEnrollments StudentEnrollment[]

  @@map("level_instances")
}

model Subject {
  id       String @id @default(uuid())
  tenantId String
  name     String
  code     String?

  tenant  Tenant    @relation(fields: [tenantId], references: [id])
  subjectTeachers SubjectTeacher[]

  @@unique([tenantId, name])
  @@map("subjects")
}

// ─── Teacher Assignment ────────────────────────────────

model ClassTeacher {
  id              String @id @default(uuid())
  userId          String
  levelInstanceId String
  tenantId         String

  user     User          @relation(fields: [userId], references: [id])
  section  LevelInstance @relation(fields: [levelInstanceId], references: [id])

  @@unique([userId, levelInstanceId])
  @@map("class_teachers")
}

model SubjectTeacher {
  id              String @id @default(uuid())
  userId          String
  subjectId       String
  levelInstanceId String
  tenantId         String

  user     User          @relation(fields: [userId], references: [id])
  subject  Subject       @relation(fields: [subjectId], references: [id])
  section  LevelInstance @relation(fields: [levelInstanceId], references: [id])

  @@unique([userId, subjectId, levelInstanceId])
  @@map("subject_teachers")
}

// ─── Students ──────────────────────────────────────────

model Student {
  id            String   @id @default(uuid())
  tenantId      String
  firstName     String
  lastName      String?
  dateOfBirth   DateTime?
  admissionNo   String?
  gender        String?
  status        String   @default("ACTIVE") // ACTIVE | TRANSFERRED | GRADUATED | ARCHIVED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  createdBy     String?

  parents       StudentParent[]
  enrollments   StudentEnrollment[]
  feePayments   FeePayment[]
  examMarks     ExamMark[]

  @@map("students")
}

model StudentParent {
  id          String  @id @default(uuid())
  studentId   String
  parentName  String
  relationship String? // FATHER | MOTHER | GUARDIAN
  phone       String?
  email       String?
  tenantId    String

  student     Student @relation(fields: [studentId], references: [id])

  @@map("student_parents")
}

model StudentEnrollment {
  id              String   @id @default(uuid())
  studentId       String
  levelInstanceId String
  academicYearId  String
  rollNumber      Int?
  enrolledAt      DateTime @default(now())
  tenantId        String

  student         Student        @relation(fields: [studentId], references: [id])
  levelInstance   LevelInstance  @relation(fields: [levelInstanceId], references: [id])
  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId])
  @@map("student_enrollments")
}

// ─── Attendance ────────────────────────────────────────

model AttendanceRecord {
  id              String   @id @default(uuid())
  studentId       String
  levelInstanceId String
  date            DateTime
  status          String   // PRESENT | ABSENT | LATE | HALF_DAY
  markedBy        String
  tenantId        String
  createdAt       DateTime @default(now())

  @@unique([studentId, levelInstanceId, date])
  @@map("attendance_records")
}

// ─── Fees ──────────────────────────────────────────────

model FeeStructure {
  id             String   @id @default(uuid())
  tenantId       String
  levelInstanceId String
  academicYearId String
  name           String   // "Tuition Fee", "Activity Fee"
  amount         Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments       FeePayment[]

  @@map("fee_structures")
}

model FeePayment {
  id             String   @id @default(uuid())
  studentId      String
  feeStructureId String
  amount         Float
  paymentDate    DateTime @default(now())
  paymentMethod  String?  // CASH | CHEQUE | ONLINE
  receivedBy     String
  tenantId       String
  receiptId      String?  @unique
  createdAt      DateTime @default(now())

  student       Student      @relation(fields: [studentId], references: [id])
  feeStructure  FeeStructure @relation(fields: [feeStructureId], references: [id])

  @@map("fee_payments")
}

// ─── Timetable ─────────────────────────────────────────

model TimetableEntry {
  id              String   @id @default(uuid())
  tenantId        String
  levelInstanceId String
  subjectId       String
  teacherId       String
  dayOfWeek       Int      // 1=Monday ... 7=Sunday
  periodNumber    Int
  room            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, levelInstanceId, dayOfWeek, periodNumber])
  @@map("timetable_entries")
}

// ─── Exams & Grades ────────────────────────────────────

model ExamSchedule {
  id             String   @id @default(uuid())
  tenantId       String
  name           String   // "Mid-Term Exam", "Final Exam"
  levelInstanceId String
  subjectId      String
  examDate       DateTime
  maxMarks       Float    @default(100)
  academicYearId String
  createdAt      DateTime @default(now())

  marks          ExamMark[]

  @@map("exam_schedules")
}

model ExamMark {
  id             String   @id @default(uuid())
  studentId      String
  examScheduleId String
  marksObtained  Float
  enteredBy      String
  tenantId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student        Student       @relation(fields: [studentId], references: [id])
  examSchedule   ExamSchedule  @relation(fields: [examScheduleId], references: [id])

  @@unique([studentId, examScheduleId])
  @@map("exam_marks")
}
