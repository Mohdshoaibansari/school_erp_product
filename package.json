{
  "name": "school-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant School ERP SaaS Platform",
  "scripts": {
    "dev": "pnpm --filter api dev",
    "build": "pnpm --filter database build && pnpm --filter shared build && pnpm --filter kernel build && pnpm --filter api build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
